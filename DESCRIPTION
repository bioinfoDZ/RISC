Package: RISC
Type: Package
Title: Robust Integration of Single-Cell RNA-Seq Datasets
Version: 1.0
Date: 2020-8-28
Authors@R: c(person("Yang", "Liu", role = c("aut", "cre"), 
         email = "yanliurisc@gmail.com"), 
